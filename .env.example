# PocketBase API URL — OAuth redirect_uri uses this host exactly (127.0.0.1 vs localhost matters for Google).
# If Google shows redirect_uri_mismatch for 127.0.0.1, add http://127.0.0.1:8090/api/oauth2-redirect in Google Cloud,
# or set URL to http://localhost:8090 and use http://localhost:8090/api/oauth2-redirect only.
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# OAuth provider id as configured in PocketBase (users → OAuth2), e.g. google
VITE_OAUTH_PROVIDER=google

# OAuth client ID and secret as configured in PocketBase (users → OAuth2)
PB_OAUTH_CLIENT_ID=
PB_OAUTH_CLIENT_SECRET=